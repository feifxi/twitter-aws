ENVIRONMENT=development
HTTP_SERVER_ADDRESS=0.0.0.0:8080

DATABASE_URL=postgresql://username:password@localhost:5432/twitter_db?sslmode=disable
# DB connection pool tuning.
# Keep DB_MIN_CONNS low for cloud environments to avoid idle connection pressure.
DB_MAX_CONNS=25
DB_MIN_CONNS=0
# Recycle connections periodically to reduce stale connection issues.
DB_MAX_CONN_LIFETIME_MINUTES=5

# Multipart handling and file upload size limits (bytes).
# 32 MiB in-memory multipart parsing budget.
MAX_MULTIPART_MEMORY_BYTES=33554432
# 100 MiB max tweet media size.
MAX_MEDIA_BYTES=104857600
# 5 MiB max avatar size.
MAX_AVATAR_BYTES=5242880

# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000
# Comma-separated trusted proxy CIDRs/IPs for real client IP extraction (leave empty for direct access/local dev)
TRUSTED_PROXIES=[IP_ADDRESS]

# Leave empty for localhost; set your domain in production (e.g. .example.com)
COOKIE_DOMAIN=
COOKIE_SAME_SITE=Lax
COOKIE_SECURE=false

# 32+ chars minimum
TOKEN_SYMMETRIC_KEY=replace-with-a-strong-32-plus-char-secret
TOKEN_DURATION_MINUTES=15
REFRESH_TOKEN_DURATION_DAYS=30

# Google OAuth Web client ID
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Azure
AZURE_STORAGE_CONTAINER_NAME=tweet-media
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string

# Redis
REDIS_ADDRESS=redis://localhost:6379
REDIS_PASSWORD=
